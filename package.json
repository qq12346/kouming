{
  "name": "kouming-workshop",
  "private": true,
  "version": "0.2.0",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "dev:electron": "concurrently \"vite --port 5173\" \"wait-on http://localhost:5173 && electron .\"",
    "build": "vite build",
    "preview": "vite preview",
    "package": "npm run build && electron-builder --mac",
    "package:win": "npm run build && electron-builder --win",
    "lint": "oxlint",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@ai-sdk/deepseek": "^3.0.7",
    "@ai-sdk/openai": "^4.0.11",
    "ai": "^7.0.22",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router": "^7.5.0",
    "zod": "^3.25.76",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.0",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.0",
    "@vitejs/plugin-react": "^6.0.3",
    "concurrently": "^9.2.0",
    "electron": "^33.4.11",
    "electron-builder": "^26.0.0",
    "oxlint": "^1.71.0",
    "tailwindcss": "^4.1.0",
    "vite": "^8.1.1",
    "vitest": "^3.1.0",
    "wait-on": "^8.0.0"
  },
  "build": {
    "appId": "com.zhizhi.kouming",
    "productName": "叩鸣·工坊",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "mac": {
      "target": "dmg",
      "category": "public.app-category.productivity"
    },
    "win": {
      "target": "nsis"
    }
  }
}
